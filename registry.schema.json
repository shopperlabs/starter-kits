{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["version", "kits"],
  "properties": {
    "version": {
      "type": "integer",
      "enum": [1]
    },
    "kits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "slug", "package", "repo", "description", "author", "shopper", "tags", "official", "preview"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "package": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+/[a-z0-9_.-]+$"
          },
          "repo": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$"
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          },
          "author": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "shopper": {
            "type": "string",
            "minLength": 1
          },
          "official": {
            "type": "boolean"
          },
          "preview": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
